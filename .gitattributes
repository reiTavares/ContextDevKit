# Normalize line endings so the engine scripts stay LF on every platform
# (silences "LF will be replaced by CRLF" warnings and keeps shebang hooks valid).
* text=auto eol=lf
*.png binary
*.jpg binary
*.ico binary
# VibeDevKit — keep engine scripts and git-hook wrappers LF on all platforms.
vibekit/**/*.mjs text eol=lf
.claude/**/*.json text eol=lf
# ContextDevKit — keep engine scripts and git-hook wrappers LF on all platforms.
contextkit/**/*.mjs text eol=lf
.claude/**/*.json text eol=lf
.codex/**/*.json text eol=lf
.codex/**/*.toml text eol=lf
