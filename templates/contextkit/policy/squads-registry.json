    {
      "squad": "devteam",
      "agent": "architect",
      "playbook": "squads/squad-devteam.md",
      "paths": [
        "src/lib/",
        "src/utils/",
        "src/core/",
        "lib/",
        "utils/",
        "package.json"
      ],
      "keywords": [
        "architecture",
        "refactor",
        "pattern",
        "rule",
        "structure",
        "type",
        "class"
      ]
    }
  ]
}
